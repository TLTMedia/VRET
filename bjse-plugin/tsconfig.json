{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "sourceMap": true,
    "declaration": true,
    "outDir": "./build",
    "declarationDir": "./declaration",
    "strictNullChecks": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "build", "declaration"],
  "include": [
    "src/**/*",
    "../src/VrmModel.ts",
    "../src/VrmLoader.ts",
    "../src/VrmaLoader.ts",
    "../src/VrmaPlayer.ts",
    "../src/Actor.ts",
    "../src/PlayController.ts"
  ]
}
